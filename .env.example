# ============================================================
# AWS
# ============================================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# ============================================================
# Confluent Cloud (Kafka)
# ============================================================
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
CONFLUENT_API_KEY=your-confluent-api-key
CONFLUENT_API_SECRET=your-confluent-api-secret

# ============================================================
# Reddit
# ============================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=pharmawatch/1.0 by your_reddit_username

# ============================================================
# Snowflake
# ============================================================
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=PHARMAWATCH_USER
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_DATABASE=PHARMAWATCH_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=PHARMAWATCH_WH
SNOWFLAKE_TRIAL_START=2025-01-01

# ============================================================
# Google Cloud
# ============================================================
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=pharmawatch

# ============================================================
# Warehouse
# ============================================================
# snowflake, bigquery, or auto
WAREHOUSE=auto

# ============================================================
# Airflow
# ============================================================
PHARMAWATCH_ROOT=/path/to/PharmaWatch
AIRFLOW_HOME=/path/to/PharmaWatch/airflow

# ============================================================
# MLflow
# ============================================================
MLFLOW_TRACKING_URI=https://your-mlflow-instance.cloud

# ============================================================
# ChromaDB
# ============================================================
CHROMA_PERSIST_DIR=/path/to/chroma_db

# ============================================================
# Groq
# ============================================================
GROQ_API_KEY=your-groq-api-key

# ============================================================
# HuggingFace / API
# ============================================================
API_BASE_URL=https://pharmawatch-api.onrender.com
